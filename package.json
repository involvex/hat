{
  "name": "@involvex/hat",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "16.18.119",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "ajv": "^8.18.0",
    "baseline-browser-mapping": "^2.10.0",
    "caniuse-lite": "^1.0.30001777",
    "jiti": "^2.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-scripts": "5.0.1",
    "styled-components": "^6.3.11",
    "typescript": "^5.1.3",
    "web-vitals": "2.1.4"
  },
  "homepage": "https://involvex.github.io/hat",
  "repository": {
    "url": "git+https://github.com/involvex/hat.git",
    "type": "git"
  },
  "author": {
    "name": "involvex"
  },
  "scripts": {
    "predeploy": "bun run build",
    "deploy": "gh-pages -d build",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prebuild": "bun run format && bun run typecheck && bun run lint:fix"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "unicode-bom": "off",
      "jsx-a11y/img-redundant-alt": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "*",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^10.0.1",
    "@involvex/prettier-config": "^0.0.4",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sort-imports": "^1.8.11",
    "typescript-eslint": "^8.56.1"
  }
}
